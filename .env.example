# RootPilot self-hosted — environment file.
# Copy to `.env` and fill in the two required secrets before `docker compose up -d`.

# REQUIRED. MySQL root password. Use a long random value, e.g.:
#   openssl rand -hex 16
DB_PASSWORD=

# REQUIRED. AES-256 key (Base64, 32 bytes) used to encrypt stored SSH credentials
# at rest. Generate ONCE and never change it — rotating this key makes every saved
# host credential undecryptable. Generate with:
#   openssl rand -base64 32
ROOTPILOT_ENCRYPT_KEY=

# Optional. Host port for the web console (bound to 127.0.0.1 only). Default 18081.
APP_PORT=18081

# Optional. Prometheus base URL (e.g. http://prometheus:9090). If set, diagnoses
# include metric trends for the incident window. Leave empty to skip metrics.
ROOTPILOT_PROMETHEUS_URL=

# Optional. Container timezone. Default UTC.
TZ=UTC
